@model StockAnalysis.Web.Models.AnalysisViewModel
@using StockAnalysis.Core.Models
@{
    ViewData["Title"] = "机会池看板";
    var tryBuy = Model.Items.Where(x => x.Signal.Decision == Decision.TryBuy).ToList();
    var buy    = Model.Items.Where(x => x.Signal.Decision == Decision.Buy).ToList();
    var watch  = Model.Items.Where(x => x.Signal.Decision == Decision.Watch).ToList();
    var others = Model.Items.Where(x => x.Signal.Decision != Decision.TryBuy
                                     && x.Signal.Decision != Decision.Buy
                                     && x.Signal.Decision != Decision.Watch).ToList();

    string RiskClass(int s) => s >= 60 ? "text-danger" : s >= 30 ? "text-warning" : "text-success";
    string DecisionLabel(Decision d) => d switch {
        Decision.TryBuy => "轻仓试错", Decision.Buy => "可以买入",
        Decision.Watch  => "观察等待", Decision.Hold => "持有不动",
        Decision.Reduce => "建议减仓", Decision.Sell => "止损离场", _ => "不参与"
    };
    string BadgeClass(Decision d) => d switch {
        Decision.TryBuy => "bg-info text-dark", Decision.Buy => "bg-success",
        Decision.Watch  => "bg-warning text-dark", _ => "bg-secondary"
    };
}

<div class="d-flex align-items-center mb-3 gap-2">
    <h4 class="mb-0">机会池看板</h4>
    <a asp-controller="Opportunity" asp-action="Index" class="btn btn-outline-secondary btn-sm ms-auto">重新分析</a>
</div>

@if (ViewBag.Failed is List<string> failed && failed.Any())
{
    <div class="alert alert-warning small">以下股票未能获取数据：@string.Join("、", failed)</div>
}

@if (!Model.Items.Any())
{
    <div class="alert alert-warning">未检测到任何信号</div>
}
else
{
    @foreach (var (group, title, borderColor) in new[] {
        (tryBuy, "今日轻仓试错", "#0dcaf0"),
        (buy,    "今日可以买入", "#198754"),
        (watch,  "今日观察等待", "#ffc107")
    })
    {
        @if (group.Any())
        {
            <h6 class="mt-3 mb-2" style="border-left:4px solid @borderColor;padding-left:8px">@title（@group.Count 只）</h6>
            <div class="table-responsive mb-3">
                <table class="table table-sm table-hover table-bordered">
                    <thead class="table-light">
                        <tr><th>代码</th><th>名称</th><th>决策</th><th>当前价</th><th>风险分</th><th>建议仓位</th><th>止损位</th><th>目标价</th><th>关键原因</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var item in group)
                        {
                            var s = item.Signal;
                            var price = item.RealTime?.Price ?? s.Close;
                            <tr>
                                <td>@s.Code</td>
                                <td>@s.Name</td>
                                <td><span class="badge @BadgeClass(s.Decision)">@DecisionLabel(s.Decision)</span></td>
                                <td>@price.ToString("F2")</td>
                                <td class="@RiskClass(s.RiskScore)">@s.RiskScore</td>
                                <td>@(s.PositionPct > 0 ? $"{s.PositionPct}%" : "-")</td>
                                <td class="text-danger">@(s.StopLossPrice?.ToString("F2") ?? "-")</td>
                                <td class="text-success">@(s.TargetPrice?.ToString("F2") ?? "-")</td>
                                <td class="small">@string.Join("、", s.Reasons.Take(2))</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    }

    @if (others.Any())
    {
        <details class="mt-2">
            <summary class="text-muted small">不参与 / 高风险（@others.Count 只）</summary>
            <div class="table-responsive mt-2">
                <table class="table table-sm table-bordered">
                    <thead class="table-light">
                        <tr><th>代码</th><th>名称</th><th>决策</th><th>风险分</th><th>原因</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var item in others)
                        {
                            <tr>
                                <td>@item.Signal.Code</td>
                                <td>@item.Signal.Name</td>
                                <td><span class="badge @BadgeClass(item.Signal.Decision)">@DecisionLabel(item.Signal.Decision)</span></td>
                                <td class="@RiskClass(item.Signal.RiskScore)">@item.Signal.RiskScore</td>
                                <td class="small">@string.Join("、", item.Signal.Reasons)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </details>
    }
}
