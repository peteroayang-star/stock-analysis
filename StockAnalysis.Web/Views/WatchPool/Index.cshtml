@using StockAnalysis.Web.Models
@{
    ViewData["Title"] = "每日机会池";
    var history = ViewBag.History as List<WatchPoolResult> ?? [];
    var hotSectors = ViewBag.HotSectors as List<string> ?? [];
}

<h4 class="mb-1">每日机会池</h4>
<p class="text-muted small mb-3">扫描热门板块，筛选"主升平台+筹码锁定"候选股，每日生成 Top 20 观察池。</p>

<div class="card mb-4">
    <div class="card-body">
        <div class="mb-3">
            <label class="form-label fw-bold">选择扫描板块（默认扫描全板块热门股）</label>
            <div class="d-flex flex-wrap gap-1 mb-2" id="sector-chips">
                @foreach (var s in hotSectors.Take(30))
                {
                    <span class="badge bg-light text-dark border sector-chip" data-sector="@s" style="cursor:pointer">@s</span>
                }
            </div>
            <div class="form-text">点击板块标签选中/取消，不选则扫描所有热门板块</div>
        </div>
        <div class="form-check mb-3">
            <input class="form-check-input" type="checkbox" id="advanced-mode">
            <label class="form-check-label" for="advanced-mode">
                高级模式：全市场扫描（耗时 5~15 分钟，默认仅扫描热门板块成分股）
            </label>
        </div>
        <button id="start-scan-btn" class="btn btn-primary btn-lg">开始扫描</button>
        <span class="text-muted small ms-3" id="scan-estimate">预计扫描 500~800 只，约 2~5 分钟</span>
    </div>
</div>

@* 扫描进度 *@
<div id="scan-progress" class="card mb-4" style="display:none">
    <div class="card-body">
        <h6>扫描进度 <span id="stat-status" class="badge bg-info"></span></h6>
        <div class="progress mb-2">
            <div id="progress-bar" class="progress-bar" style="width:0%">0%</div>
        </div>
        <div class="row small text-muted">
            <div class="col-md-4">
                已处理：<strong id="stat-processed">0</strong> / <span id="stat-total">0</span>
            </div>
            <div class="col-md-4">
                已命中：<strong id="stat-matched" class="text-success">0</strong> 只
            </div>
            <div class="col-md-4">
                已过滤：<strong id="stat-filtered" class="text-warning">0</strong> 只
            </div>
            <div class="col-md-4 mt-1">
                当前：<span id="stat-current">-</span>
            </div>
            <div class="col-md-4 mt-1">
                数据源：<span id="stat-source">-</span>
            </div>
            <div class="col-md-4 mt-1">
                失败：<strong id="stat-failed" class="text-danger">0</strong> 只
            </div>
        </div>
        <div id="stat-message" class="alert alert-warning mt-2 small" style="display:none"></div>
    </div>
</div>

@if (history.Any())
{
    <h6 class="mb-2">历史记录</h6>
    <div class="list-group" style="max-width:400px">
        @foreach (var h in history)
        {
            <a href="@Url.Action("Result", new { date = h.Date.ToString("yyyy-MM-dd") })"
               class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                <span>@h.Date.ToString("yyyy-MM-dd")</span>
                <span class="text-muted small">入选 @h.Items.Count 只 / 扫描 @h.ScannedCount 只</span>
            </a>
        }
    </div>
}

@section Scripts {
<script>
(function() {
    var selectedSectors = [];
    var isScanning = false;
    var pollTimer = null;

    document.querySelectorAll('.sector-chip').forEach(function(chip) {
        chip.addEventListener('click', function() {
            var s = this.dataset.sector;
            if (selectedSectors.includes(s)) {
                selectedSectors = selectedSectors.filter(function(x) { return x !== s; });
                this.classList.remove('bg-primary', 'text-white');
                this.classList.add('bg-light', 'text-dark');
            } else {
                selectedSectors.push(s);
                this.classList.remove('bg-light', 'text-dark');
                this.classList.add('bg-primary', 'text-white');
            }
        });
    });

    document.getElementById('advanced-mode').addEventListener('change', function() {
        document.getElementById('scan-estimate').textContent = this.checked
            ? '预计扫描 5000+ 只，约 5~15 分钟' : '预计扫描 500~800 只，约 2~5 分钟';
    });

    document.getElementById('start-scan-btn').addEventListener('click', function() {
        if (isScanning) return;
        isScanning = true;
        this.disabled = true;
        this.textContent = '扫描中...';
        document.getElementById('scan-progress').style.display = 'block';

        var formData = new FormData();
        formData.append('sectors', selectedSectors.join(','));
        formData.append('advanced', document.getElementById('advanced-mode').checked);

        fetch('/WatchPool/Generate', { method: 'POST', body: formData })
            .then(function(r) { return r.json(); })
            .then(function(data) {
                pollProgress(data.scanId);
            })
            .catch(function() {
                isScanning = false;
                document.getElementById('start-scan-btn').disabled = false;
                document.getElementById('start-scan-btn').textContent = '开始扫描';
            });
    });

    function pollProgress(scanId) {
        pollTimer = setInterval(function() {
            fetch('/WatchPool/Progress?scanId=' + scanId)
                .then(function(r) { return r.json(); })
                .then(function(p) {
                    // 更新进度条
                    if (p.total > 0) {
                        var pct = p.percent || Math.round(p.processed / p.total * 100);
                        document.getElementById('progress-bar').style.width = pct + '%';
                        document.getElementById('progress-bar').textContent = pct + '%';
                    }
                    // 更新所有统计数字
                    document.getElementById('stat-processed').textContent = p.processed;
                    document.getElementById('stat-total').textContent = p.total;
                    document.getElementById('stat-matched').textContent = p.matched;
                    document.getElementById('stat-filtered').textContent = p.filtered;
                    document.getElementById('stat-failed').textContent = p.failed;
                    document.getElementById('stat-current').textContent = p.currentStock || '-';
                    document.getElementById('stat-source').textContent = p.currentSource || '-';
                    document.getElementById('stat-status').textContent = p.status || 'Idle';
                    document.getElementById('stat-status').className = 'badge ' +
                        (p.status === 'Completed' ? 'bg-success' :
                         p.status === 'Failed' ? 'bg-danger' :
                         p.status === 'Running' ? 'bg-info' : 'bg-secondary');

                    // 处理失败状态
                    if (p.status === 'Failed') {
                        clearInterval(pollTimer);
                        document.getElementById('stat-message').style.display = 'block';
                        document.getElementById('stat-message').textContent = p.message || '扫描失败';
                        document.getElementById('start-scan-btn').disabled = false;
                        document.getElementById('start-scan-btn').textContent = '重新扫描';
                        isScanning = false;
                        return;
                    }

                    // 处理完成状态
                    if (p.done) {
                        clearInterval(pollTimer);
                        if (p.matched > 0 || p.total > 0) {
                            // 有结果，跳转
                            setTimeout(function() {
                                window.location.href = '/WatchPool/Result';
                            }, 500);
                        } else {
                            // 扫描完成但无结果
                            document.getElementById('stat-message').style.display = 'block';
                            document.getElementById('stat-message').textContent =
                                '扫描完成但未命中任何股票。可能原因：快照数据为空、所有候选股被过滤、或命中条件过严。请检查后端控制台日志。';
                            document.getElementById('start-scan-btn').disabled = false;
                            document.getElementById('start-scan-btn').textContent = '重新扫描';
                            isScanning = false;
                        }
                    }
                })
                .catch(function() {
                    // 网络错误，继续轮询
                });
        }, 2000);
    }
})();
</script>
}
