@using StockAnalysis.Web.Models
@using StockAnalysis.Core.Engines
@model WatchPoolResult
@{
    ViewData["Title"] = "机会池结果";
    string TierClass(string t) => t == "激进" ? "danger" : t == "重点" ? "warning" : "secondary";
    string EmotionLabel(string c) => c switch {
        "Climax" => "高潮", "Consensus" => "一致", "Divergence" => "分歧",
        "Recovery" => "修复", "Decline" => "退潮", "IcePoint" => "冰点", _ => "-"
    };
    string RiskClass(int s) => s <= 30 ? "text-success fw-bold" : s <= 50 ? "text-warning fw-bold" : "text-danger fw-bold";
    string ResClass(decimal r) => r >= 75 ? "text-success fw-bold" : r >= 50 ? "text-warning fw-bold" : "text-danger fw-bold";
    string HeatClass(decimal h) => h >= 80 ? "text-success fw-bold" : h >= 65 ? "text-warning fw-bold" : "text-muted";
    var valueItems = Model.Items.Where(x => x.IsValuePool).ToList();
}

<div class="d-flex align-items-center gap-3 mb-3 flex-wrap">
    <h4 class="mb-0">机会池 · @Model.Date.ToString("yyyy-MM-dd")</h4>
    <span class="text-muted small">
        扫描 @Model.ScannedCount 只 &nbsp;|&nbsp;
        失败 @Model.FailedCount 只 &nbsp;|&nbsp;
        过滤 @Model.FilteredCount 只 &nbsp;|&nbsp;
        入选 <strong>@Model.Items.Count</strong> 只
        @if (valueItems.Any()) { <span>&nbsp;|&nbsp; 价值池 <strong class="text-success">@valueItems.Count</strong> 只</span> }
    </span>
    <div class="ms-auto d-flex gap-2">
        <a href="@Url.Action("ExportCsv", new { date = Model.Date.ToString("yyyy-MM-dd") })" class="btn btn-sm btn-outline-success">导出 CSV</a>
        <a asp-action="Index" class="btn btn-sm btn-outline-secondary">返回</a>
    </div>
</div>

@* ── 数据源状态 ── *@
<div class="alert @(Model.DataSourceFailCount > 0 ? "alert-warning" : "alert-info") py-2 mb-3 small">
    <strong>数据源：</strong>@Model.DataSourceName &nbsp;|&nbsp;
    <strong>接口失败：</strong>@Model.DataSourceFailCount 次 &nbsp;|&nbsp;
    <strong>已跳过：</strong>@Model.SkippedCount 只 &nbsp;|&nbsp;
    @if (Model.UsingCache) { <span class="text-warning fw-bold">使用缓存数据</span> }
    else { <span class="text-success">实时数据</span> }
    @if (Model.DataSourceWarnings.Any())
    {
        <br/>
        <span class="text-muted">@string.Join(" / ", Model.DataSourceWarnings.Take(3))</span>
    }
</div>

@* ── 主线板块分析 ── *@
@if (Model.Top10Sectors.Any())
{
    <div class="card mb-3">
        <div class="card-header py-2 d-flex align-items-center gap-2">
            <strong>当前 Top10 主线板块</strong>
            <span class="text-muted small ms-auto">热度≥80=主线 / ≥65=强势 / &lt;50=冷门</span>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-sm table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>#</th>
                            <th>板块名称</th>
                            <th>热度分</th>
                            <th>上涨/涨停</th>
                            <th>龙头强度</th>
                            <th>资金方向</th>
                            <th>连续性</th>
                            <th>状态</th>
                            <th>轮动信号</th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (int i = 0; i < Model.Top10Sectors.Count; i++)
                        {
                            var sec = Model.Top10Sectors[i];
                            var rotation = Model.SectorRotations.FirstOrDefault(r => r.SectorName == sec.SectorName);
                            <tr>
                                <td class="text-muted">@(i + 1)</td>
                                <td><strong>@sec.SectorName</strong></td>
                                <td class="@HeatClass(sec.SectorHeatScore)">@sec.SectorHeatScore.ToString("F0")</td>
                                <td>@sec.RisingCount / <span class="text-danger">@sec.LimitUpCount</span></td>
                                <td>@sec.SectorLeaderStrength.ToString("F0")</td>
                                <td>@(sec.SectorCapitalFlow >= 60 ? "净流入" : sec.SectorCapitalFlow >= 40 ? "中性" : "净流出")</td>
                                <td>@sec.SectorContinuity.ToString("F0")</td>
                                <td>
                                    @if (sec.IsMainstream) { <span class="badge bg-success">主线</span> }
                                    else if (sec.IsHotSector) { <span class="badge bg-warning text-dark">强势</span> }
                                    else if (sec.IsDeclining) { <span class="badge bg-danger">退潮</span> }
                                    else { <span class="badge bg-secondary">一般</span> }
                                </td>
                                <td class="small text-muted">
                                    @if (rotation?.IsStrengthening == true) { <span class="text-success">↑ 加强</span> }
                                    else if (rotation?.IsWeakening == true) { <span class="text-danger">↓ 退潮</span> }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

@if (valueItems.Any())
{
    <div class="alert alert-success py-2 mb-3">
        <strong>主升浪价值池（@valueItems.Count 只）：</strong>
        @string.Join("、", valueItems.Select(x => $"{x.Name}({x.Code})"))
    </div>
}

@if (!Model.Items.Any())
{
    <div class="alert alert-info">今日未发现符合条件的候选股</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover align-middle table-sm">
            <thead class="table-light">
                <tr>
                    <th>#</th>
                    <th>代码/名称</th>
                    <th>所属板块</th>
                    <th>当前价</th>
                    <th>市值(亿)</th>
                    <th>综合分</th>
                    <th>共振分</th>
                    <th>二波概率</th>
                    <th>平台锁仓</th>
                    <th>筹码锁定</th>
                    <th>板块情绪</th>
                    <th>上涨/涨停</th>
                    <th>风险分</th>
                    <th>决策</th>
                    <th>层级</th>
                    <th>入选理由 / 风险提示</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Items)
                {
                    <tr class="@(item.IsValuePool ? "table-success" : item.IsSectorDeclining ? "table-danger" : "")">
                        <td class="text-muted">@item.Rank</td>
                        <td>
                            <strong>@item.Code</strong><br/>
                            <span class="text-muted small">@item.Name</span>
                            @if (item.IsValuePool) { <br/><span class="badge bg-success">价值池</span> }
                        </td>
                        <td class="small">
                            @item.Sector
                            @if (item.IsMainstreamSector) { <br/><span class="badge bg-success">主线</span> }
                            else if (item.IsSectorDeclining) { <br/><span class="badge bg-danger">退潮</span> }
                            @if (!string.IsNullOrEmpty(item.SectorRotationNote))
                            { <br/><span class="text-muted" style="font-size:0.75em">@item.SectorRotationNote</span> }
                        </td>
                        <td>@item.Price.ToString("F2")</td>
                        <td>@(item.MarketCap.HasValue ? item.MarketCap.Value.ToString("F0") : "-")</td>
                        <td><strong>@item.WatchPoolScore.ToString("F1")</strong></td>
                        <td class="@ResClass(item.ResonanceScore)">@item.ResonanceScore.ToString("F0")</td>
                        <td>@item.SecondWaveProbability.ToString("F0")%</td>
                        <td>@item.LockPositionStrength.ToString("F0")</td>
                        <td>@item.ChipLockScore.ToString("F0")</td>
                        <td>@EmotionLabel(item.SectorEmotion)</td>
                        <td class="small">@item.SectorRisingCount / @item.SectorLimitUpCount</td>
                        <td class="@RiskClass(item.RiskScore)">@item.RiskScore</td>
                        <td>@item.Decision</td>
                        <td><span class="badge bg-@TierClass(item.Tier)">@item.Tier</span></td>
                        <td class="small text-muted" style="max-width:260px">
                            @if (item.IsIndependentPump) { <span class="badge bg-danger me-1">孤立拉升</span> }
                            @if (item.IsFakeBreakoutRisk) { <span class="badge bg-warning text-dark me-1">诱多风险</span> }
                            @item.Reason
                            @if (!string.IsNullOrEmpty(item.RiskWarning))
                            { <br/><span class="text-warning">⚠ @item.RiskWarning</span> }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
