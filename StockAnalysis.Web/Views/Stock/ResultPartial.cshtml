@model StockAnalysis.Web.Models.AnalysisViewModel
@using StockAnalysis.Core.Models
@using StockAnalysis.Core.Engines
@{
    var allCodes  = Model.Items.Where(x => x.RealTime != null).Select(x => x.Signal.Code).ToList();
    var firstItem = Model.Items.FirstOrDefault();

    string DecisionLabel(Decision d) => d switch {
        Decision.Buy    => "🟢 趋势向上", Decision.TryBuy => "🟢 突破确认",
        Decision.Watch  => "🟡 观察等待", Decision.Hold   => "🔵 持有观察",
        Decision.Reduce => "🟠 高位博弈", Decision.Sell   => "🔴 风险增强",
        _               => "⚪ 观察股票"
    };
    string DecisionTagClass(Decision d) => d switch {
        Decision.Buy    => "tag tag-buy",    Decision.TryBuy => "tag tag-trybuy",
        Decision.Watch  => "tag tag-watch",  Decision.Hold   => "tag tag-hold",
        Decision.Reduce => "tag tag-reduce", Decision.Sell   => "tag tag-sell",
        _               => "tag tag-ignore"
    };
    string DecisionBorderClass(Decision d) => d switch {
        Decision.Buy    => "decision-buy",   Decision.TryBuy => "decision-trybuy",
        Decision.Watch  => "decision-watch", Decision.Hold   => "decision-hold",
        Decision.Reduce => "decision-reduce",Decision.Sell   => "decision-sell",
        _               => "decision-ignore"
    };
    string CycleTagClass(string stage) => stage.Contains("主升") ? "tag tag-cycle-up"
        : stage.Contains("启动") ? "tag tag-cycle-up"
        : stage.Contains("一致") || stage.Contains("分歧") ? "tag tag-cycle-mid"
        : "tag tag-cycle-down";
    string SmartMoneyLabel(SmartMoneyBehavior b) => b switch {
        SmartMoneyBehavior.Accumulation     => "资金吸筹",
        SmartMoneyBehavior.Washout          => "洗盘整理",
        SmartMoneyBehavior.DivergenceSwap   => "高位分歧",
        SmartMoneyBehavior.AggressiveAttack => "主动进攻",
        SmartMoneyBehavior.HighShock        => "高位震荡",
        SmartMoneyBehavior.Distribution     => "疑似派发",
        SmartMoneyBehavior.Dumping          => "资金流出",
        _                                   => ""
    };
    string SmartMoneyTagClass(SmartMoneyBehavior b) => b switch {
        SmartMoneyBehavior.AggressiveAttack                                    => "tag tag-smart-attack",
        SmartMoneyBehavior.Accumulation or SmartMoneyBehavior.Washout          => "tag tag-smart-accum",
        SmartMoneyBehavior.Distribution or SmartMoneyBehavior.Dumping          => "tag tag-smart-dist",
        SmartMoneyBehavior.DivergenceSwap or SmartMoneyBehavior.HighShock      => "tag tag-smart-wash",
        _                                                                      => "tag tag-smart-other"
    };
    string RiskTagClass(int score) => score >= 70 ? "tag tag-risk-ext"
        : score >= 50 ? "tag tag-risk-high"
        : score >= 25 ? "tag tag-risk-mid"
        : "tag tag-risk-low";
    string RiskLabel(int score) => score >= 70 ? "极高风险" : score >= 50 ? "高风险" : score >= 25 ? "中风险" : "低风险";
    string RiskBarColor(int score) => score >= 70 ? "#dc3545" : score >= 50 ? "#fd7e14" : score >= 25 ? "#ffc107" : "#198754";

    string TrendClass(Trend t) => t switch { Trend.Up => "up", Trend.Down => "down", _ => "warn" };
    string TrendLabel(Trend t) => t switch { Trend.Up => "上涨偏强", Trend.Down => "下跌偏弱", _ => "震荡中性" };
    string TrendStageLabel(TrendStage s) => s switch {
        TrendStage.EarlyUp => "主升初期", TrendStage.MidUp => "主升中期",
        TrendStage.LateUp  => "主升末期", TrendStage.Down  => "下跌阶段", _ => "震荡整理"
    };
    string SignalLabel(BuySignalType t) => t switch {
        BuySignalType.VolumeBreakout  => "倍量突破",
        BuySignalType.PullbackSupport => "缩量回踩",
        BuySignalType.VolumeWashout   => "凹量洗盘",
        BuySignalType.TrendPullback   => "趋势回调",
        _                             => ""
    };
}

<div id="analysis-result-container"
     data-code="@(firstItem?.Signal.Code ?? "")"
     data-name="@(firstItem?.Signal.Name ?? "")">

@{
    var ignoreItems2    = Model.Items.Where(x => x.Signal.Decision == Decision.Ignore).ToList();
    var mainCodes2      = Model.Items.Where(x => x.Signal.Decision != Decision.Ignore).Select(x => x.Signal.Code).ToHashSet();
    var filteredIgnore2 = ignoreItems2.Where(x => !mainCodes2.Contains(x.Signal.Code)).ToList();
}

@if (!Model.Items.Any())
{
    <div class="alert alert-warning">
        未检测到任何信号（数据不足或被过滤）
        @if (ViewBag.ExcludeReason != null)
        { <span>— 过滤原因：<strong>@ViewBag.ExcludeReason</strong></span> }
    </div>
}
else
{
    @foreach (var item in Model.Items)
    {
        var s = item.Signal;
        var rt = item.RealTime;
        var pctClass = rt != null ? (rt.ChangePct >= 0 ? "up" : "down") : "";
        var pctSign  = rt != null && rt.ChangePct >= 0 ? "+" : "";
        var amountStr = rt != null ? (rt.Amount >= 10000 ? $"{rt.Amount/10000:F1}亿" : $"{rt.Amount:F0}万") : "";
        var emotionIcon = rt != null && rt.ChangePct >= 9.9m ? "📈"
            : rt != null && rt.ChangePct >= 5m ? "↗"
            : rt != null && rt.ChangePct <= -5m ? "↘"
            : !string.IsNullOrEmpty(s.VolumeDescription) && s.VolumeDescription.Contains("放量") ? "📊"
            : !string.IsNullOrEmpty(s.VolumeDescription) && s.VolumeDescription.Contains("缩量") ? "—"
            : "";
        <div class="terminal-card @DecisionBorderClass(s.Decision)">

            <div class="layer-1">
                <!-- 行1：名称 + 决策标签 -->
                <div class="l1-row-name">
                    <span class="stock-name">@s.Name</span>
                    <span class="stock-code">@s.Code</span>
                    <span class="@DecisionTagClass(s.Decision) decision-main">@DecisionLabel(s.Decision)</span>
                    <span style="color:#888;font-size:12px;margin-left:auto">@s.Date.ToString("yyyy-MM-dd")</span>
                </div>
                <!-- 行2：价格主视觉 -->
                <div class="l1-row-price">
                    @if (rt != null)
                    {
                        <span class="price-main @pctClass">@rt.Price.ToString("F2")</span>
                        <span class="price-pct @pctClass rt-pct">@pctSign@rt.ChangePct.ToString("F2")%</span>
                    }
                    else
                    {
                        <span class="price-main" style="color:#aaa">@s.Close.ToString("F2")</span>
                    }
                    @if (!string.IsNullOrEmpty(emotionIcon))
                    { <span class="emotion-icon">@emotionIcon</span> }
                </div>
                <!-- 行3：辅助标签 -->
                <div class="l1-row-tags">
                    @if (s.IsEmotionLeader)
                    { <span class="tag tag-smart-attack">情绪龙头</span> }

                    @* 风险标签体系 *@
                    @{
                        var riskTag = "";
                        var riskClass = "tag tag-smart-dist";

                        // 1. 情绪投机型：连板+高换手+短期涨幅大
                        if (s.LimitUpCountIn14Days >= 2 && rt != null && rt.Turnover > 15 && rt.ChangePct > 5)
                        {
                            riskTag = "⚠ 情绪投机型";
                        }
                        // 2. 财务风险型：业绩下滑
                        else if (item.FinanceRiskAdj > 15)
                        {
                            riskTag = "⚠ 财务风险型";
                        }
                        // 3. 低价高波动型：价格低+波动大
                        else if (s.Close < 5 && s.VolatilityRisk >= 40)
                        {
                            riskTag = "⚠ 低价高波动型";
                        }
                        // 4. 游资博弈型：高换手+放量滞涨
                        else if (rt != null && rt.Turnover > 20 && s.VolumeDescription?.Contains("放量滞涨") == true)
                        {
                            riskTag = "⚠ 游资博弈型";
                        }
                        // 5. 高位分歧型：高位+放量派发
                        else if (s.VolumeDescription?.Contains("放量派发") == true || s.SupportBroken)
                        {
                            riskTag = "⚠ 高位分歧型";
                        }
                        // 6. 综合高风险：风险分≥70
                        else if (s.RiskScore >= 70 || s.SentimentRisk >= 70)
                        {
                            riskTag = "⚠ 综合高风险";
                        }

                        if (!string.IsNullOrEmpty(riskTag))
                        {
                            <span class="@riskClass">@riskTag</span>
                        }
                    }

                    @if (!string.IsNullOrEmpty(s.CycleStage))
                    { <span class="@CycleTagClass(s.CycleStage)">@s.CycleStage</span> }
                    @if (!string.IsNullOrEmpty(s.VolumeDescription))
                    {
                        <span class="tag tag-smart-other">@s.VolumeDescription</span>
                        var volumeExplain = s.VolumeDescription switch {
                            "放量进攻" => "新增资金参与度提升",
                            "缩量整理" or "缩量回踩" => "抛压暂时有限，持续性需观察",
                            "放量滞涨" => "高位分歧增强，追价意愿下降",
                            "放量派发" => "兑现压力增强",
                            "弱承接" => "承接力度偏弱",
                            "无量横盘" => "市场进入观望阶段",
                            _ => ""
                        };
                        if (!string.IsNullOrEmpty(volumeExplain))
                        {
                            <span class="tag" style="background:#2d3748;color:#9CA3AF;border:none">@volumeExplain</span>
                        }
                    }
                    @if (s.SmartMoney != SmartMoneyBehavior.None)
                    { <span class="@SmartMoneyTagClass(s.SmartMoney)">@SmartMoneyLabel(s.SmartMoney)</span> }
                    <span class="@RiskTagClass(s.RiskScore)">@RiskLabel(s.RiskScore) @s.RiskScore</span>
                    @if (s.LimitUpCountIn14Days > 0)
                    { <span class="tag tag-buy">14日内涨停@(s.LimitUpCountIn14Days)次</span> }
                </div>
            </div>

            
            @if (rt != null)
            {
                <div class="layer-2" data-rt="@s.Code">
                    <span>开 <b class="rt-open">@rt.Open.ToString("F2")</b></span>
                    <span>高 <b class="rt-high">@rt.High.ToString("F2")</b></span>
                    <span>低 <b class="rt-low">@rt.Low.ToString("F2")</b></span>
                    <span>昨收 <b class="rt-preclose">@rt.PreClose.ToString("F2")</b></span>
                    <span>成交额 <b class="rt-amount">@amountStr</b></span>
                    @if (rt.Turnover > 0) { <span>换手 <b class="rt-turnover">@rt.Turnover.ToString("F2")%</b></span> }
                    <span style="color:#9CA3AF">@s.Date.ToString("yyyy-MM-dd")</span>
                </div>
            }

            <div class="layer-3">
                <!-- 市场状态分析 -->
                <div class="l3-block" style="grid-column: 1 / -1; background:#1a1f2e;padding:12px;border-radius:4px;margin-bottom:12px">
                    <div class="l3-title" style="color:#60A5FA">当前市场状态</div>
                    <div class="l3-value" style="font-size:14px;color:#E5E7EB;margin-top:8px">
                        @{
                            var marketState = (s.VolumeDescription, s.Trend, s.TrendStage) switch {
                                (var v, Trend.Up, TrendStage.EarlyUp) when v.Contains("放量") => "放量突破阶段",
                                (var v, Trend.Up, _) when v.Contains("缩量") => "缩量上涨阶段",
                                (var v, _, _) when v.Contains("放量滞涨") => "高位分歧阶段",
                                (var v, Trend.Sideways, _) when v.Contains("缩量") => "缩量整理阶段",
                                (var v, Trend.Down, _) when v.Contains("放量") => "放量回调阶段",
                                (_, Trend.Up, TrendStage.LateUp) => "趋势修复阶段",
                                (var v, _, _) when v.Contains("回踩") => "回踩确认阶段",
                                _ => "资金博弈阶段"
                            };
                        }
                        <strong>@marketState</strong>
                    </div>
                    <div style="color:#9CA3AF;font-size:12px;margin-top:8px;line-height:1.6">
                        @if (!string.IsNullOrEmpty(s.VolumeDescription))
                        {
                            <div>· 量价关系：@s.VolumeDescription</div>
                        }
                        @if (s.Trend != Trend.Sideways)
                        {
                            <div>· 趋势状态：@TrendLabel(s.Trend)</div>
                        }
                        @if (rt != null && s.Close > 0)
                        {
                            var volRatio = rt.Amount / (s.Close * 10000);
                            if (volRatio > 1.3m)
                            {
                                <div>· 成交量较前期提升 @(((volRatio - 1) * 100).ToString("F0"))%</div>
                            }
                        }
                    </div>
                </div>

                <div class="layer-3-grid">

                    
                    <div class="l3-block">
                        <div class="l3-title">交易依据</div>
                        <div class="l3-value @TrendClass(s.Trend) mb-1">@TrendLabel(s.Trend) · @TrendStageLabel(s.TrendStage)</div>
                        @if (s.SignalType != BuySignalType.None)
                        { <div class="l3-value mb-1" style="color:#ffc107">信号：@SignalLabel(s.SignalType)</div> }
                        <div class="l3-value" style="color:#D1D5DB;font-size:12px">@s.ActionAdvice</div>
                        @if (s.PositionPct > 0 && s.IntradayPatternType != IntradayPattern.TailTrap && !s.IntradayDangerZone)
                        { <div class="mt-2"><span class="tag tag-hold">建议仓位 @s.PositionPct%</span></div> }
                    </div>


                    <div class="l3-block">
                        <div class="l3-title">风险拆分</div>
                        @foreach (var (label, val, cls) in new[] { ("趋势", s.TrendRisk, "trend-row"), ("波动", s.VolatilityRisk, "volatility-row"), ("情绪", s.SentimentRisk, "sentiment") })
                        {
                            <div class="risk-row @cls @(label == "情绪" && val >= 50 ? "high-sentiment" : "")">
                                <span class="risk-label">@label</span>
                                <div class="risk-bar-wrap">
                                    <div class="risk-bar" style="width:@(Math.Min(val,100))%;background:@RiskBarColor(val)"></div>
                                </div>
                                <span class="risk-num">@val</span>
                            </div>
                        }
                        @if (s.Reasons.Any())
                        {
                            <div class="mt-2" style="color:#9CA3AF;font-size:11px">
                                @foreach (var r in s.Reasons.Take(2)) { <div>· @r</div> }
                            </div>
                        }

                        @* 承接分析 *@
                        @if (rt != null && s.SupportPrice.HasValue)
                        {
                            var supportHold = rt.Price >= s.SupportPrice.Value;
                            var priceNearMA = s.SupportPrice.HasValue && Math.Abs(rt.Price - s.SupportPrice.Value) / s.SupportPrice.Value < 0.02m;
                            <div class="mt-2 pt-2" style="border-top:1px solid #374151">
                                <div style="color:#9CA3AF;font-size:11px;font-weight:600;margin-bottom:4px">承接观察</div>
                                @if (supportHold)
                                {
                                    <div style="color:#10B981;font-size:11px">· 均线支撑有效</div>
                                }
                                else if (s.SupportBroken)
                                {
                                    <div style="color:#EF4444;font-size:11px">· 已跌破关键均线</div>
                                }
                                @if (s.VolumeDescription?.Contains("缩量") == true && rt.ChangePct < 0)
                                {
                                    <div style="color:#9CA3AF;font-size:11px">· 回落缩量，恐慌不明显</div>
                                }
                                @if (s.VolumeDescription?.Contains("放量") == true && rt.ChangePct < -2)
                                {
                                    <div style="color:#F59E0B;font-size:11px">· 放量回落，抛压增加</div>
                                }
                            </div>
                        }
                    </div>


                    <div class="l3-block">
                        <div class="l3-title">关键价位</div>
                        <div class="d-flex flex-column gap-1" style="font-size:12px">
                            @if (s.SupportPrice.HasValue)
                            {
                                <div class="d-flex justify-content-between">
                                    <span style="color:#9CA3AF">支撑 MA20 @(s.SupportBroken ? "⚠已跌破" : "")</span>
                                    <span class="@(s.SupportBroken ? "l3-value down" : "l3-value")">@s.SupportPrice.Value.ToString("F2")</span>
                                </div>
                                @if (s.SupportBroken)
                                {
                                    <div style="color:#9CA3AF;font-size:11px">跌破后：短线趋势可能转弱</div>
                                }
                            }
                            @if (s.StopLossPrice.HasValue)
                            {
                                var stopTriggered = rt != null && rt.Price < s.StopLossPrice.Value;
                                <div class="d-flex justify-content-between">
                                    <span style="color:#9CA3AF">止损 @(stopTriggered ? "⚠已触发" : "-2%")</span>
                                    <span class="l3-value down">@s.StopLossPrice.Value.ToString("F2")</span>
                                </div>
                                @if (stopTriggered)
                                {
                                    <div style="color:#9CA3AF;font-size:11px">触发后：量价结构将明显恶化</div>
                                }
                            }
                            @if (s.WatchPrice.HasValue)
                            {
                                <div class="d-flex justify-content-between">
                                    <span style="color:#9CA3AF">观察位</span>
                                    <span class="l3-value warn">@s.WatchPrice.Value.ToString("F2")</span>
                                </div>
                            }
                            @if (s.TargetPrice.HasValue && s.Decision != Decision.Watch)
                            {
                                <div class="d-flex justify-content-between">
                                    <span style="color:#9CA3AF">目标价</span>
                                    <span class="l3-value up">@s.TargetPrice.Value.ToString("F2")</span>
                                </div>
                                <div style="color:#9CA3AF;font-size:11px">若放量突破：可能进入加速段</div>
                            }
                        </div>
                    </div>

                </div>

                @* 分时主动资金强度 *@
                @if (s.IntradayStrengthScore > 0)
                {
                    var intradayColor = s.IntradayStrengthScore >= 65 ? "#10B981"
                        : s.IntradayStrengthScore >= 40 ? "#F59E0B" : "#EF4444";
                    var willColor = s.AttackWillDescription == "强" ? "#10B981"
                        : s.AttackWillDescription == "中" ? "#F59E0B" : "#EF4444";
                    var gradeColor = s.AttackGrade == AttackGrade.S ? "#10B981"
                        : s.AttackGrade == AttackGrade.A ? "#60A5FA"
                        : s.AttackGrade == AttackGrade.B ? "#F59E0B" : "#EF4444";
                    var gradeLabel = s.AttackGrade switch {
                        AttackGrade.S => "S 主升抢筹",
                        AttackGrade.A => s.IntradayPatternType == IntradayPattern.StepwiseUp ? "A 阶梯推升" : "A 强势承接",
                        AttackGrade.B => s.IntradayPatternType == IntradayPattern.TrendShock ? "B+ 趋势震荡偏强" : "B 修复震荡",
                        _             => "C 尾盘诱多"
                    };
                    <div class="l3-block" style="grid-column: 1 / -1; background:#1a1f2e;padding:12px;border-radius:4px;margin-top:12px">
                        <div class="l3-title" style="color:#60A5FA">分时主动资金强度</div>
                        <div style="display:flex;align-items:center;gap:16px;margin-top:8px;flex-wrap:wrap">
                            <div>
                                <span style="color:#9CA3AF;font-size:11px">强度评分</span>
                                <div style="font-size:22px;font-weight:700;color:@intradayColor">@s.IntradayStrengthScore</div>
                            </div>
                            <div>
                                <span style="color:#9CA3AF;font-size:11px">进攻等级</span>
                                <div style="font-size:16px;font-weight:700;color:@gradeColor">@gradeLabel</div>
                            </div>
                            <div>
                                <span style="color:#9CA3AF;font-size:11px">进攻意愿</span>
                                <div style="font-size:16px;font-weight:600;color:@willColor">@s.AttackWillDescription</div>
                            </div>
                            <div>
                                <span style="color:#9CA3AF;font-size:11px">形态判断</span>
                                <div style="font-size:13px;color:#E5E7EB;margin-top:2px">@s.IntradayPattern</div>
                            </div>
                            @if (!s.IntradayDangerZone && s.NextDayLimitUpScore > 0)
                            {
                                var limitColor = s.NextDayLimitUpScore >= 60 ? "#10B981"
                                    : s.NextDayLimitUpScore >= 35 ? "#F59E0B" : "#9CA3AF";
                                <div>
                                    <span style="color:#9CA3AF;font-size:11px">次日涨停潜力</span>
                                    <div style="font-size:16px;font-weight:600;color:@limitColor">@s.NextDayLimitUpScore</div>
                                </div>
                            }
                        </div>
                        <div style="margin-top:8px;background:#111827;border-radius:3px;height:6px;overflow:hidden">
                            <div style="width:@(s.IntradayStrengthScore)%;height:100%;background:@intradayColor;transition:width .3s"></div>
                        </div>
                        @if (s.IntradayPatternType == IntradayPattern.TailTrap || s.IntradayDangerZone)
                        {
                            <div style="margin-top:12px;padding:10px 14px;background:#450a0a;border:2px solid #dc2626;border-radius:4px">
                                <span style="color:#ef4444;font-size:16px;font-weight:700;letter-spacing:1px">⚠ 危险：存在尾盘修复/诱多风险，不建议追高</span>
                            </div>
                        }
                        @* 短弱长强桥接说明 *@
                        @if (s.IntradayStrengthScore < 40 && !s.IntradayDangerZone && s.MainForceBehavior != null
                             && s.MainForceBehavior.Stage is MarketStage.WashoutDip or MarketStage.TrendRelay
                                                          or MarketStage.LaunchTest or MarketStage.MainUpAccel)
                        {
                            <div style="margin-top:10px;padding:8px 12px;background:#1e2a1e;border-left:3px solid #4ade80;border-radius:3px">
                                <span style="color:#86efac;font-size:12px;font-weight:600">短弱长强</span>
                                <span style="color:#9CA3AF;font-size:12px;margin-left:8px">当日分时偏弱属正常波动，日K趋势结构未破坏，两者不矛盾。</span>
                            </div>
                        }
                    </div>
                }


                @* 主力行为识别 *@
                @if (s.MainForceBehavior != null)
                {
                    var mf = s.MainForceBehavior;
                    string ProbColor(int v) => v >= 60 ? "#10B981" : v >= 35 ? "#F59E0B" : "#9CA3AF";
                    string DistColor(int v)  => v >= 50 ? "#EF4444" : v >= 30 ? "#F59E0B" : "#9CA3AF";
                    string StageLabel(MarketStage st) => st switch {
                        MarketStage.Accumulation  => "底部吸筹期",
                        MarketStage.LaunchTest    => "启动试盘期",
                        MarketStage.WashoutDip    => "分歧洗筹期",
                        MarketStage.TrendRelay    => "趋势中继期",
                        MarketStage.MainUpAccel   => "主升加速期",
                        MarketStage.TopDistribute => "高位派发期",
                        MarketStage.Exhaustion    => "退潮衰竭期",
                        _ => ""
                    };
                    string StageColor(MarketStage st) => st switch {
                        MarketStage.MainUpAccel   => "#10B981",
                        MarketStage.TrendRelay or MarketStage.WashoutDip or MarketStage.LaunchTest => "#60A5FA",
                        MarketStage.TopDistribute or MarketStage.Exhaustion => "#EF4444",
                        _ => "#9CA3AF"
                    };
                    <div class="l3-block" style="grid-column:1/-1;background:#1a1f2e;padding:12px;border-radius:4px;margin-top:12px">
                        <div style="display:flex;align-items:center;gap:10px">
                            <div class="l3-title" style="color:#A78BFA">主力行为识别</div>
                            <span style="padding:2px 10px;border-radius:3px;font-size:13px;font-weight:700;background:rgba(255,255,255,.07);color:@StageColor(mf.Stage)">@StageLabel(mf.Stage)</span>
                        </div>
                        <div style="display:flex;gap:20px;flex-wrap:wrap;margin-top:10px">
                            @foreach (var (label, val, color) in new[]{
                                ("洗盘概率",    mf.WashProbability,         ProbColor(mf.WashProbability)),
                                ("出货概率",    mf.DistributionProbability, DistColor(mf.DistributionProbability)),
                                ("主升预备",    mf.BreakoutProbability,     ProbColor(mf.BreakoutProbability)),
                                ("趋势健康度",  mf.TrendHealthScore,        ProbColor(mf.TrendHealthScore)),
                                ("控盘强度",    mf.ControlStrength,         ProbColor(mf.ControlStrength)),
                                ("筹码锁定度",  mf.LockupScore,             ProbColor(mf.LockupScore))
                            })
                            {
                                <div style="min-width:80px">
                                    <div style="color:#9CA3AF;font-size:11px">@label</div>
                                    <div style="font-size:20px;font-weight:700;color:@color">@val</div>
                                    <div style="background:#111827;border-radius:3px;height:4px;margin-top:4px;overflow:hidden">
                                        <div style="width:@(val)%;height:100%;background:@color"></div>
                                    </div>
                                </div>
                            }
                        </div>
                        @if (mf.BehaviorTags.Any())
                        {
                            <div style="margin-top:10px;display:flex;flex-wrap:wrap;gap:6px">
                                @foreach (var tag in mf.BehaviorTags)
                                {
                                    var tagColor = tag.Contains("出货") || tag.Contains("破位") || tag.Contains("滞涨") || tag.Contains("长阴")
                                        ? "#450a0a;color:#f87171" : "rgba(167,139,250,.15);color:#A78BFA";
                                    <span style="padding:2px 8px;border-radius:3px;font-size:12px;background:@tagColor">@tag</span>
                                }
                            </div>
                        }
                        <div style="margin-top:10px;color:#D1D5DB;font-size:13px;line-height:1.7;background:#111827;padding:10px;border-radius:4px">
                            @mf.Analysis
                        </div>
                    </div>
                }

                @* 主升平台结构 *@
                @if (s.MainUpPlatform != null)
                {
                    var plat = s.MainUpPlatform;
                    string LockColor(decimal v) => v >= 70 ? "#2d6a4f" : v >= 50 ? "#e9c46a" : "#9CA3AF";
                    string ProbColor2(decimal v) => v >= 65 ? "#2d6a4f" : v >= 50 ? "#e9c46a" : "#9CA3AF";
                    <div class="l3-block" style="grid-column:1/-1;background:#1a1f2e;padding:12px;border-radius:4px;margin-top:12px">
                        <div class="l3-title" style="color:#34d399">主升平台结构</div>
                        @if (plat.IsMainUpPlatform)
                        {
                            <div style="display:flex;gap:20px;flex-wrap:wrap;margin-top:10px">
                                <div><div style="color:#9CA3AF;font-size:11px">平台天数</div><div style="font-size:20px;font-weight:700;color:#E5E7EB">@plat.PlatformDays 天</div></div>
                                <div><div style="color:#9CA3AF;font-size:11px">平台振幅</div><div style="font-size:20px;font-weight:700;color:#E5E7EB">@(plat.PlatformRangePercent.ToString("P1"))</div></div>
                                <div><div style="color:#9CA3AF;font-size:11px">锁仓强度</div><div style="font-size:20px;font-weight:700;color:@LockColor(plat.LockPositionStrength)">@plat.LockPositionStrength.ToString("F0")</div></div>
                                <div><div style="color:#9CA3AF;font-size:11px">二波概率</div><div style="font-size:20px;font-weight:700;color:@ProbColor2(plat.SecondWaveProbability)">@plat.SecondWaveProbability.ToString("F0")%</div></div>
                                <div><div style="color:#9CA3AF;font-size:11px">突破准备度</div><div style="font-size:20px;font-weight:700;color:@ProbColor2(plat.BreakoutReadyScore)">@plat.BreakoutReadyScore.ToString("F0")</div></div>
                            </div>
                            @if (plat.Tags.Any())
                            {
                                <div style="margin-top:8px;display:flex;flex-wrap:wrap;gap:6px">
                                    @foreach (var tag in plat.Tags)
                                    { <span style="padding:2px 8px;border-radius:3px;font-size:12px;background:rgba(52,211,153,.15);color:#34d399">@tag</span> }
                                </div>
                            }
                        }
                        <div style="margin-top:10px;color:#D1D5DB;font-size:13px;background:#111827;padding:10px;border-radius:4px">@plat.Summary</div>
                    </div>
                }

                @* 龙虎榜行为 *@
                @if (s.DragonTiger != null)
                {
                    var dt = s.DragonTiger;
                    <div class="l3-block" style="grid-column:1/-1;background:#1a1f2e;padding:12px;border-radius:4px;margin-top:12px">
                        <div class="l3-title" style="color:#f59e0b">龙虎榜行为</div>
                        @if (dt.IsOnDragonTigerList)
                        {
                            <div style="display:flex;gap:20px;flex-wrap:wrap;margin-top:10px">
                                <div><div style="color:#9CA3AF;font-size:11px">近10日上榜</div><div style="font-size:20px;font-weight:700;color:#E5E7EB">@dt.ListedDaysIn10 次</div></div>
                                <div><div style="color:#9CA3AF;font-size:11px">游资接力</div><div style="font-size:20px;font-weight:700;color:@(dt.RelayStrength>=70?"#2d6a4f":dt.RelayStrength>=50?"#e9c46a":"#9CA3AF")">@dt.RelayStrength.ToString("F0")</div></div>
                                <div><div style="color:#9CA3AF;font-size:11px">机构参与</div><div style="font-size:20px;font-weight:700;color:#E5E7EB">@(dt.InstitutionBuyRatio.ToString("P0"))</div></div>
                                <div><div style="color:#9CA3AF;font-size:11px">一日游风险</div><div style="font-size:16px;font-weight:700;color:@(dt.IsOneDayTour?"#e76f51":"#2d6a4f")">@(dt.IsOneDayTour?"是":"否")</div></div>
                                <div><div style="color:#9CA3AF;font-size:11px">锁仓特征</div><div style="font-size:16px;font-weight:700;color:@(dt.IsLockPosition?"#2d6a4f":"#9CA3AF")">@(dt.IsLockPosition?"是":"否")</div></div>
                            </div>
                            @if (dt.Tags.Any())
                            {
                                <div style="margin-top:8px;display:flex;flex-wrap:wrap;gap:6px">
                                    @foreach (var tag in dt.Tags)
                                    { <span style="padding:2px 8px;border-radius:3px;font-size:12px;background:rgba(245,158,11,.15);color:#f59e0b">@tag</span> }
                                </div>
                            }
                        }
                        else
                        {
                            <div style="margin-top:8px;color:#6B7280;font-size:13px">暂无龙虎榜数据</div>
                        }
                        <div style="margin-top:10px;color:#D1D5DB;font-size:13px;background:#111827;padding:10px;border-radius:4px">@dt.Summary</div>
                    </div>
                }

                @* 板块情绪 *@
                @if (s.SectorEmotion != null)
                {
                    var se = s.SectorEmotion;
                    string CycleColor(SectorEmotionCycle c) => c switch {
                        SectorEmotionCycle.Consensus => "#2d6a4f",
                        SectorEmotionCycle.Climax    => "#e76f51",
                        SectorEmotionCycle.Decline   => "#e76f51",
                        SectorEmotionCycle.Recovery  => "#e9c46a",
                        SectorEmotionCycle.Divergence => "#e9c46a",
                        _ => "#9CA3AF"
                    };
                    string CycleLabel(SectorEmotionCycle c) => c switch {
                        SectorEmotionCycle.IcePoint   => "冰点",
                        SectorEmotionCycle.Recovery   => "修复",
                        SectorEmotionCycle.Divergence => "分歧",
                        SectorEmotionCycle.Consensus  => "一致",
                        SectorEmotionCycle.Climax     => "高潮",
                        SectorEmotionCycle.Decline    => "退潮",
                        _ => "-"
                    };
                    <div class="l3-block" style="grid-column:1/-1;background:#1a1f2e;padding:12px;border-radius:4px;margin-top:12px">
                        <div class="l3-title" style="color:#60A5FA">板块情绪</div>
                        <div style="display:flex;gap:20px;flex-wrap:wrap;margin-top:10px">
                            <div><div style="color:#9CA3AF;font-size:11px">所属板块</div><div style="font-size:16px;font-weight:700;color:#E5E7EB">@se.SectorName</div></div>
                            <div><div style="color:#9CA3AF;font-size:11px">情绪周期</div><div style="font-size:20px;font-weight:700;color:@CycleColor(se.Cycle)">@CycleLabel(se.Cycle)</div></div>
                            <div><div style="color:#9CA3AF;font-size:11px">板块强度</div><div style="font-size:20px;font-weight:700;color:#E5E7EB">@se.SectorStrengthScore.ToString("F0")</div></div>
                            <div><div style="color:#9CA3AF;font-size:11px">分歧风险</div><div style="font-size:20px;font-weight:700;color:@(se.DivergenceRisk>=70?"#e76f51":se.DivergenceRisk>=50?"#e9c46a":"#9CA3AF")">@se.DivergenceRisk.ToString("F0")</div></div>
                        </div>
                        <div style="margin-top:10px;color:#D1D5DB;font-size:13px;background:#111827;padding:10px;border-radius:4px">@se.Summary</div>
                    </div>
                }

                @* 板块共振 *@
                @if (s.SectorResonance != null)
                {
                    var sr = s.SectorResonance;
                    string ResColor(decimal v) => v >= 75 ? "#2d6a4f" : v >= 50 ? "#e9c46a" : "#e76f51";
                    <div class="l3-block" style="grid-column:1/-1;background:#1a1f2e;padding:12px;border-radius:4px;margin-top:12px">
                        <div class="l3-title" style="color:#f59e0b">板块共振分析</div>
                        <div style="display:flex;gap:20px;flex-wrap:wrap;margin-top:10px">
                            <div><div style="color:#9CA3AF;font-size:11px">共振评分</div><div style="font-size:20px;font-weight:700;color:@ResColor(sr.ResonanceScore)">@sr.ResonanceScore.ToString("F0")</div></div>
                            <div><div style="color:#9CA3AF;font-size:11px">板块趋势</div><div style="font-size:16px;font-weight:700;color:#E5E7EB">@sr.SectorTrend</div></div>
                            <div><div style="color:#9CA3AF;font-size:11px">上涨/总数</div><div style="font-size:16px;font-weight:700;color:#E5E7EB">@sr.SectorRisingCount / @(sr.SectorRisingCount + sr.SectorFallingCount)</div></div>
                            <div><div style="color:#9CA3AF;font-size:11px">涨停数</div><div style="font-size:16px;font-weight:700;color:@(sr.SectorLimitUpCount>=2?"#2d6a4f":"#9CA3AF")">@sr.SectorLimitUpCount</div></div>
                            <div><div style="color:#9CA3AF;font-size:11px">龙头状态</div><div style="font-size:14px;font-weight:700;color:@(sr.IsSectorLeading?"#2d6a4f":"#e76f51")">@(sr.IsSectorLeading?"强势":"走弱")</div></div>
                            <div><div style="color:#9CA3AF;font-size:11px">孤立拉升</div><div style="font-size:14px;font-weight:700;color:@(sr.IsIndependentPump?"#e76f51":"#2d6a4f")">@(sr.IsIndependentPump?"是":"否")</div></div>
                            <div><div style="color:#9CA3AF;font-size:11px">诱多风险</div><div style="font-size:14px;font-weight:700;color:@(sr.IsFakeBreakoutRisk?"#e76f51":"#2d6a4f")">@(sr.IsFakeBreakoutRisk?"是":"否")</div></div>
                        </div>
                        @if (sr.Tags.Any())
                        {
                            <div style="margin-top:8px;display:flex;flex-wrap:wrap;gap:6px">
                                @foreach (var tag in sr.Tags)
                                { <span style="padding:2px 8px;border-radius:3px;font-size:12px;background:rgba(245,158,11,.15);color:#f59e0b">@tag</span> }
                            </div>
                        }
                        <div style="margin-top:10px;color:#D1D5DB;font-size:13px;background:#111827;padding:10px;border-radius:4px">@sr.SectorSummary</div>
                    </div>
                }

                @* 筹码控盘 *@
                @if (s.ChipControl != null)
                {
                    var cc = s.ChipControl;
                    string ScoreColor(decimal v) => v >= 70 ? "#2d6a4f" : v >= 50 ? "#e9c46a" : "#e76f51";
                    <div class="l3-block" style="grid-column:1/-1;background:#1a1f2e;padding:12px;border-radius:4px;margin-top:12px">
                        <div class="l3-title" style="color:#a78bfa">筹码控盘</div>
                        <div style="display:flex;gap:20px;flex-wrap:wrap;margin-top:10px">
                            <div><div style="color:#9CA3AF;font-size:11px">承接强度</div><div style="font-size:20px;font-weight:700;color:@ScoreColor(cc.SupportStrength)">@cc.SupportStrength.ToString("F0")</div></div>
                            <div><div style="color:#9CA3AF;font-size:11px">筹码锁定</div><div style="font-size:20px;font-weight:700;color:@ScoreColor(cc.ChipLockScore)">@cc.ChipLockScore.ToString("F0")</div></div>
                            <div><div style="color:#9CA3AF;font-size:11px">抗跌能力</div><div style="font-size:20px;font-weight:700;color:@ScoreColor(cc.DownsideResistance)">@cc.DownsideResistance.ToString("F0")</div></div>
                            <div><div style="color:#9CA3AF;font-size:11px">强承接</div><div style="font-size:16px;font-weight:700;color:@(cc.IsStrongSupport?"#2d6a4f":"#9CA3AF")">@(cc.IsStrongSupport?"是":"否")</div></div>
                            <div><div style="color:#9CA3AF;font-size:11px">派发嫌疑</div><div style="font-size:16px;font-weight:700;color:@(cc.IsDistributionSuspected?"#e76f51":"#2d6a4f")">@(cc.IsDistributionSuspected?"是":"否")</div></div>
                        </div>
                        @if (cc.Tags.Any())
                        {
                            <div style="margin-top:8px;display:flex;flex-wrap:wrap;gap:6px">
                                @foreach (var tag in cc.Tags)
                                { <span style="padding:2px 8px;border-radius:3px;font-size:12px;background:rgba(167,139,250,.15);color:#a78bfa">@tag</span> }
                            </div>
                        }
                        <div style="margin-top:10px;color:#D1D5DB;font-size:13px;background:#111827;padding:10px;border-radius:4px">@cc.Summary</div>
                    </div>
                }

                @if (item.Finance != null && item.Finance.Periods.Length > 0)
                {
                    <div class="layer-finance">
                        <details open>
                            <summary>
                                业绩数据
                                @if (item.FinanceRiskAdj != 0)
                                {
                                    var adjSign = item.FinanceRiskAdj > 0 ? "+" : "";
                                    <span class="@(item.FinanceRiskAdj > 0 ? "l3-value down" : "l3-value up") ms-2">风险调整 @adjSign@item.FinanceRiskAdj</span>
                                }
                            </summary>
                            <div class="d-flex gap-3 flex-wrap mt-2">
                                @for (int i = 0; i < item.Finance.Periods.Length; i++)
                                {
                                    var yoy    = item.Finance.ProfitYoy.Length > i ? item.Finance.ProfitYoy[i] : double.NaN;
                                    var revYoy = item.Finance.RevenueYoy.Length > i ? item.Finance.RevenueYoy[i] : double.NaN;
                                    bool yi = double.IsNaN(yoy) || double.IsInfinity(yoy);
                                    bool ri = double.IsNaN(revYoy) || double.IsInfinity(revYoy);
                                    <div class="finance-card">
                                        <div class="fc-period">@item.Finance.Periods[i]</div>
                                        <div class="fc-row">净利润 <span class="@(yi?"":"l3-value "+(yoy>0?"up":"down"))">@(yi?"-":$"{yoy:F1}%")</span></div>
                                        <div class="fc-row">营收 <span class="@(ri?"":"l3-value "+(revYoy>0?"up":"down"))">@(ri?"-":$"{revYoy:F1}%")</span></div>
                                    </div>
                                }
                            </div>
                        </details>
                    </div>
                }
            </div>

        </div>
    }

}

</div>

@if (allCodes.Any())
{
<script>
(function () {
    var nodes = document.querySelectorAll('[data-rt]');
    if (!nodes.length) return;
    var codes = Array.from(nodes).map(n => n.dataset.rt).join(',');
    var interval = 10, timer;

    function isTradingTime() {
        var now = new Date(), day = now.getDay();
        if (day === 0 || day === 6) return false;
        var mins = now.getHours() * 60 + now.getMinutes();
        return mins >= 9 * 60 + 15 && mins < 15 * 60;
    }
    function fmt(v) { return parseFloat(v).toFixed(2); }

    function refresh() {
        fetch('/Stock/RealTimeQuotes?codes=' + encodeURIComponent(codes))
            .then(r => r.json())
            .then(data => {
                nodes.forEach(function (el) {
                    var q = data[el.dataset.rt];
                    if (!q) return;
                    var card = el.closest('.terminal-card');
                    if (card) {
                        var priceEl = card.querySelector('.price-main');
                        var pctEl   = card.querySelector('.rt-pct');
                        if (priceEl) { priceEl.textContent = fmt(q.price); priceEl.className = 'price-main ' + (q.changePct >= 0 ? 'up' : 'down'); }
                        if (pctEl)   { pctEl.textContent = (q.changePct >= 0 ? '+' : '') + fmt(q.changePct) + '%'; pctEl.className = 'price-pct rt-pct ' + (q.changePct >= 0 ? 'up' : 'down'); }
                    }
                    var o = el.querySelector('.rt-open');    if (o) o.textContent = fmt(q.open);
                    var h = el.querySelector('.rt-high');    if (h) h.textContent = fmt(q.high);
                    var l = el.querySelector('.rt-low');     if (l) l.textContent = fmt(q.low);
                    var p = el.querySelector('.rt-preclose');if (p) p.textContent = fmt(q.preClose);
                });
                var st = document.getElementById('rt-status');
                if (st) st.textContent = '已更新 ' + new Date().toLocaleTimeString();
            });
    }

    function startCountdown() {
        var cdEl = document.getElementById('rt-countdown');
        if (!isTradingTime()) {
            var st = document.getElementById('rt-status');
            if (st) st.textContent = '非交易时间';
            if (cdEl) cdEl.textContent = '--';
            return;
        }
        var left = interval;
        if (cdEl) cdEl.textContent = left + 's';
        timer = setInterval(function () {
            left--;
            if (cdEl) cdEl.textContent = left + 's';
            if (left <= 0) { clearInterval(timer); refresh(); startCountdown(); }
        }, 1000);
    }

    refresh();
    startCountdown();
    var btn = document.getElementById('rt-refresh-btn');
    if (btn) btn.addEventListener('click', function () { clearInterval(timer); refresh(); startCountdown(); });
})();
</script>
}
