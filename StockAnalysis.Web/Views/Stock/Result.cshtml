@model StockAnalysis.Web.Models.AnalysisViewModel
@{
    ViewData["Title"] = "交易决策面板";
    var firstItem = Model.Items.FirstOrDefault();
    var firstCode = firstItem?.Signal.Code ?? "";
    var firstName = firstItem?.Signal.Name ?? "";
    var allCodes  = Model.Items.Where(x => x.RealTime != null).Select(x => x.Signal.Code).ToList();
}

<div class="d-flex align-items-center mb-2 gap-2" style="color:#888;font-size:12px">
    <span>交易决策面板</span>
    @if (allCodes.Any())
    {
        <span id="rt-status" class="ms-2">股价刷新中…</span>
        <span id="rt-countdown" style="color:#555">10s</span>
        <button id="rt-refresh-btn" class="tb-btn" style="padding:2px 8px;font-size:11px">刷新</button>
    }
</div>

@await Html.PartialAsync("ResultPartial", Model)

@section Scripts {
<script>
// 页面加载时初始化工具栏状态
(function () {
    var code = '@Html.Raw(firstCode)', name = '@Html.Raw(firstName)';
    if (!code) return;

    // 加入最近浏览
    function load(k) { try { return JSON.parse(localStorage.getItem(k) || '[]'); } catch { return []; } }
    function save(k, v) { localStorage.setItem(k, JSON.stringify(v)); }
    var recent = load('tb_recent').filter(x => x.code !== code);
    recent.unshift({ code, name });
    if (recent.length > 10) recent = recent.slice(0, 10);
    save('tb_recent', recent);

    // 更新星标
    var starBtn = document.getElementById('tb-watchlist-star');
    if (starBtn) {
        starBtn.dataset.code = code;
        starBtn.dataset.name = name;
        var inWl = load('tb_watchlist').some(x => x.code === code);
        starBtn.classList.toggle('starred', inWl);
        starBtn.textContent = inWl ? '★ 已观察' : '★ 观察';
    }
})();
</script>
}
