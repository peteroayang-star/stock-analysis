@model StockAnalysis.Web.Models.SignalWithSuggestion
@using StockAnalysis.Core.Models
@using StockAnalysis.Core.Engines
@{
    var s = Model.Signal;
    var rt = Model.RealTime;
    var pctClass = rt != null ? (rt.ChangePct >= 0 ? "up" : "down") : "";
    var pctSign  = rt != null && rt.ChangePct >= 0 ? "+" : "";
    var amountStr = rt != null ? (rt.Amount >= 10000 ? $"{rt.Amount/10000:F1}亿" : $"{rt.Amount:F0}万") : "";
    var emotionIcon = rt != null && rt.ChangePct >= 9.9m ? "📈"
        : rt != null && rt.ChangePct >= 5m ? "↗"
        : rt != null && rt.ChangePct <= -5m ? "↘"
        : !string.IsNullOrEmpty(s.VolumeDescription) && s.VolumeDescription.Contains("放量") ? "📊"
        : !string.IsNullOrEmpty(s.VolumeDescription) && s.VolumeDescription.Contains("缩量") ? "—"
        : "";

    string DecisionLabel(Decision d) => d switch {
        Decision.Buy    => "🟢 趋势向上", Decision.TryBuy => "🟢 突破确认",
        Decision.Watch  => "🟡 观察等待", Decision.Hold   => "🔵 持有观察",
        Decision.Reduce => "🟠 高位博弈", Decision.Sell   => "🔴 风险增强",
        _               => "⚪ 观察股票"
    };
    string DecisionTagClass(Decision d) => d switch {
        Decision.Buy    => "tag tag-buy",    Decision.TryBuy => "tag tag-trybuy",
        Decision.Watch  => "tag tag-watch",  Decision.Hold   => "tag tag-hold",
        Decision.Reduce => "tag tag-reduce", Decision.Sell   => "tag tag-sell",
        _               => "tag tag-ignore"
    };
    string CycleTagClass(string stage) => stage.Contains("主升") ? "tag tag-cycle-up"
        : stage.Contains("启动") ? "tag tag-cycle-up"
        : stage.Contains("一致") || stage.Contains("分歧") ? "tag tag-cycle-mid"
        : "tag tag-cycle-down";
    string SmartMoneyLabel(SmartMoneyBehavior b) => b switch {
        SmartMoneyBehavior.Accumulation     => "资金吸筹",
        SmartMoneyBehavior.Washout          => "洗盘整理",
        SmartMoneyBehavior.DivergenceSwap   => "高位分歧",
        SmartMoneyBehavior.AggressiveAttack => "主动进攻",
        SmartMoneyBehavior.HighShock        => "高位震荡",
        SmartMoneyBehavior.Distribution     => "疑似派发",
        SmartMoneyBehavior.Dumping          => "资金流出",
        _                                   => ""
    };
    string SmartMoneyTagClass(SmartMoneyBehavior b) => b switch {
        SmartMoneyBehavior.AggressiveAttack                                    => "tag tag-smart-attack",
        SmartMoneyBehavior.Accumulation or SmartMoneyBehavior.Washout          => "tag tag-smart-accum",
        SmartMoneyBehavior.Distribution or SmartMoneyBehavior.Dumping          => "tag tag-smart-dist",
        SmartMoneyBehavior.DivergenceSwap or SmartMoneyBehavior.HighShock      => "tag tag-smart-wash",
        _                                                                      => "tag tag-smart-other"
    };
    string RiskTagClass(int score) => score >= 70 ? "tag tag-risk-ext"
        : score >= 50 ? "tag tag-risk-high"
        : score >= 25 ? "tag tag-risk-mid"
        : "tag tag-risk-low";
    string RiskLabel(int score) => score >= 70 ? "极高风险" : score >= 50 ? "高风险" : score >= 25 ? "中风险" : "低风险";
    string SignalLabel(BuySignalType t) => t switch {
        BuySignalType.VolumeBreakout  => "倍量突破",
        BuySignalType.PullbackSupport => "缩量回踩",
        BuySignalType.VolumeWashout   => "凹量洗盘",
        BuySignalType.TrendPullback   => "趋势回调",
        _                             => ""
    };
}

@* 统一结论卡片 *@
<div style="background:#111827;border:1px solid #1F2937;border-radius:6px;padding:12px 16px;margin-bottom:10px">
    <div style="display:flex;align-items:center;gap:16px;flex-wrap:wrap">
        <div style="display:flex;align-items:center;gap:6px">
            <span style="color:#9CA3AF;font-size:11px">操作状态</span>
            <span style="font-size:15px;font-weight:700;color:@(s.Decision switch { Decision.Buy or Decision.TryBuy => "#10B981", Decision.Watch or Decision.Hold => "#3B82F6", Decision.Reduce => "#F59E0B", Decision.Sell or Decision.Ignore => "#EF4444", _ => "#9CA3AF" });background:@(s.Decision switch { Decision.Buy or Decision.TryBuy => "#10B981", Decision.Watch or Decision.Hold => "#3B82F6", Decision.Reduce => "#F59E0B", Decision.Sell or Decision.Ignore => "#EF4444", _ => "#9CA3AF" })20;padding:3px 10px;border-radius:4px">@(s.Decision switch { Decision.Buy or Decision.TryBuy => "买入观察", Decision.Watch => "继续观察", Decision.Hold => "持有", Decision.Reduce => "减仓", Decision.Sell or Decision.Ignore => "规避", _ => "继续观察" })</span>
        </div>
        <div style="color:#374151">|</div>
        <div style="display:flex;align-items:center;gap:6px">
            <span style="color:#9CA3AF;font-size:11px">风险等级</span>
            <span style="font-size:15px;font-weight:700;color:@(s.RiskScore >= 50 ? "#EF4444" : s.RiskScore >= 25 ? "#F59E0B" : "#10B981");background:@(s.RiskScore >= 50 ? "#EF4444" : s.RiskScore >= 25 ? "#F59E0B" : "#10B981")20;padding:3px 10px;border-radius:4px">@(s.RiskScore >= 50 ? "高" : s.RiskScore >= 25 ? "中" : "低")</span>
        </div>
        <div style="color:#374151">|</div>
        <div style="display:flex;align-items:center;gap:6px">
            <span style="color:#9CA3AF;font-size:11px">趋势阶段</span>
            <span style="font-size:15px;font-weight:700;color:#60A5FA;background:rgba(96,165,250,.15);padding:3px 10px;border-radius:4px">@(s.DetailedStage switch { DetailedTrendStage.Launch => "启动", DetailedTrendStage.TrendBuilding => "增强", DetailedTrendStage.MainUpEarly or DetailedTrendStage.MainUpMid => "主升", DetailedTrendStage.MainUpLate or DetailedTrendStage.HighShock => "高位", DetailedTrendStage.DistributionRisk or DetailedTrendStage.TrendDecline => "退潮", _ => "启动" })</span>
        </div>
        <div style="color:#374151">|</div>
        <div style="display:flex;align-items:center;gap:12px;flex-wrap:wrap">
            <span style="color:#9CA3AF;font-size:11px">关键价位</span>
            <span style="font-size:13px">支撑 <b style="color:#E5E7EB">@(s.SupportPrice?.ToString("F2") ?? "-")</b></span>
            <span style="font-size:13px">观察 <b style="color:#E5E7EB">@(s.WatchPrice?.ToString("F2") ?? "-")</b></span>
            <span style="font-size:13px">止损 <b style="color:#EF4444">@(s.StopLossPrice?.ToString("F2") ?? "-")</b></span>
            @if (s.TargetPrice.HasValue) { <span style="font-size:13px">目标 <b style="color:#10B981">@s.TargetPrice.Value.ToString("F2")</b></span> }
        </div>
    </div>
</div>

<div class="layer-1">
    <!-- 行1：名称 + 决策标签 -->
    <div class="l1-row-name">
        <span class="stock-name">@s.Name</span>
        <span class="stock-code">@s.Code</span>
        <span class="@DecisionTagClass(s.Decision) decision-main">@DecisionLabel(s.Decision)</span>
        <span style="color:#888;font-size:12px;margin-left:auto">@s.Date.ToString("yyyy-MM-dd")</span>
    </div>
    <!-- 行2：价格主视觉 -->
    <div class="l1-row-price">
        @if (rt != null)
        {
            <span class="price-main @pctClass">@rt.Price.ToString("F2")</span>
            <span class="price-pct @pctClass rt-pct">@pctSign@rt.ChangePct.ToString("F2")%</span>
        }
        else
        {
            <span class="price-main" style="color:#aaa">@s.Close.ToString("F2")</span>
        }
        @if (!string.IsNullOrEmpty(emotionIcon))
        { <span class="emotion-icon">@emotionIcon</span> }
    </div>
    <!-- 行3：辅助标签 -->
    <div class="l1-row-tags">
        @* PositionEngine 统一阶段标签 *@
        @{
            string stageLabel = s.DetailedStage switch {
                DetailedTrendStage.Launch => "启动期",
                DetailedTrendStage.TrendBuilding => "趋势增强",
                DetailedTrendStage.MainUpEarly => "主升初期",
                DetailedTrendStage.MainUpMid => "主升中期",
                DetailedTrendStage.MainUpLate => "主升末端",
                DetailedTrendStage.HighShock => "高位震荡",
                DetailedTrendStage.DistributionRisk => "出货风险",
                DetailedTrendStage.TrendDecline => "趋势衰退",
                _ => ""
            };
            string stageClass = s.DetailedStage switch {
                DetailedTrendStage.MainUpEarly or DetailedTrendStage.MainUpMid => "tag tag-cycle-up",
                DetailedTrendStage.MainUpLate or DetailedTrendStage.DistributionRisk => "tag tag-cycle-down",
                DetailedTrendStage.HighShock => "tag tag-cycle-mid",
                _ => "tag tag-smart-other"
            };
            if (!string.IsNullOrEmpty(stageLabel))
            { <span class="@stageClass">@stageLabel</span> }

            // 位置等级
            string posLabel = s.PositionLevel switch {
                PositionLevel.Low => "低位", PositionLevel.Mid => "中位", PositionLevel.High => "高位", _ => ""
            };
            <span class="tag tag-smart-other">@posLabel</span>

            // 过度延伸警告
            if (s.IsOverextended)
            { <span class="tag tag-risk-ext">偏离过大</span> }
        }

        @* 情绪标签（PositionEngine 驱动） *@
        @if (s.IsEmotionLeader)
        { <span class="tag tag-smart-attack">情绪龙头</span> }
        else if (s.IsEmotionActive)
        { <span class="tag tag-smart-other">情绪活跃</span> }

        @* 风险分 + 主力 *@
        <span class="@RiskTagClass(s.RiskScore)">@RiskLabel(s.RiskScore) @s.RiskScore</span>
        @if (s.SmartMoney != SmartMoneyBehavior.None)
        { <span class="@SmartMoneyTagClass(s.SmartMoney)">@SmartMoneyLabel(s.SmartMoney)</span> }
        @if (s.LimitUpCountIn14Days > 0)
        { <span class="tag tag-buy">14日内涨停@(s.LimitUpCountIn14Days)次</span> }
    </div>
</div>

@if (rt != null)
{
    <div class="layer-2" data-rt="@s.Code">
        <span>开 <b class="rt-open">@rt.Open.ToString("F2")</b></span>
        <span>高 <b class="rt-high">@rt.High.ToString("F2")</b></span>
        <span>低 <b class="rt-low">@rt.Low.ToString("F2")</b></span>
        <span>昨收 <b class="rt-preclose">@rt.PreClose.ToString("F2")</b></span>
        <span>成交额 <b class="rt-amount">@amountStr</b></span>
        @if (rt.Turnover > 0) { <span>换手 <b class="rt-turnover">@rt.Turnover.ToString("F2")%</b></span> }
        <span style="color:#9CA3AF">@s.Date.ToString("yyyy-MM-dd")</span>
    </div>
}

@* 关键价格一行 + 折叠按钮 *@
<div class="layer-keyprices d-flex align-items-center gap-3 mt-1 small">
    <span>止损 <b class="text-danger">@(s.StopLossPrice?.ToString("F2") ?? "-")</b></span>
    <span>支撑 <b>@(s.SupportPrice?.ToString("F2") ?? "-")</b></span>
    <span>观察 <b>@(s.WatchPrice?.ToString("F2") ?? "-")</b></span>
    @if (s.TargetPrice.HasValue) { <span>目标 <b class="text-success">@s.TargetPrice.Value.ToString("F2")</b></span> }
    <button class="btn btn-sm btn-outline-secondary ms-auto toggle-detail-btn" type="button"
            onclick="var d=this.closest('.terminal-card').querySelector('.layer-3,.ai-analysis-section,.layer-finance');d.style.display=d.style.display==='none'?'':'none';this.textContent=d.style.display==='none'?'展开详细分析':'收起详细分析'">
        收起详细分析
    </button>
</div>
